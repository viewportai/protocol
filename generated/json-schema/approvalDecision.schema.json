{
  "$ref": "#/definitions/viewport.approval_decision/v1",
  "definitions": {
    "viewport.approval_decision/v1": {
      "type": "object",
      "properties": {
        "schema": {
          "type": "string",
          "const": "viewport.approval_decision/v1"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "subjectType": {
          "type": "string",
          "minLength": 1
        },
        "subjectId": {
          "type": "string",
          "minLength": 1
        },
        "subjectDigest": {
          "type": "string",
          "pattern": "^sha256:[A-Za-z0-9._-]+$"
        },
        "decision": {
          "type": "string",
          "enum": [
            "approve",
            "deny",
            "request_changes"
          ]
        },
        "actor": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "source": {
              "type": "string",
              "minLength": 1
            },
            "displayName": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "id"
          ],
          "additionalProperties": false
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "executionGrant": {
          "type": "object",
          "properties": {
            "schema": {
              "type": "string",
              "const": "viewport.execution_grant/v1"
            },
            "digest": {
              "type": "string",
              "pattern": "^sha256:[A-Za-z0-9._-]+$"
            },
            "proposalKey": {
              "type": "string",
              "minLength": 1
            },
            "approvalDecisionKey": {
              "type": "string",
              "minLength": 1
            },
            "issuedAt": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": [
            "schema",
            "digest",
            "proposalKey",
            "approvalDecisionKey",
            "issuedAt"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "schema",
        "id",
        "subjectType",
        "subjectId",
        "subjectDigest",
        "decision",
        "actor",
        "createdAt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
