{
  "$ref": "#/definitions/viewport.audit_receipt/v1",
  "definitions": {
    "viewport.audit_receipt/v1": {
      "type": "object",
      "properties": {
        "schema": {
          "type": "string",
          "const": "viewport.audit_receipt/v1"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "workspaceId": {
          "type": "string",
          "minLength": 1
        },
        "workflowRunId": {
          "type": "string",
          "minLength": 1
        },
        "eventType": {
          "type": "string",
          "minLength": 1
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "actor": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "source": {
              "type": "string",
              "minLength": 1
            },
            "displayName": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "id"
          ],
          "additionalProperties": false
        },
        "route": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "integer",
              "exclusiveMinimum": 0
            }
          },
          "required": [
            "id",
            "version"
          ],
          "additionalProperties": false
        },
        "executionProfile": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "integer",
              "exclusiveMinimum": 0
            }
          },
          "required": [
            "id",
            "version"
          ],
          "additionalProperties": false
        },
        "workflow": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "schema": {
              "type": "string",
              "const": "viewport.workflow/v1"
            },
            "digest": {
              "type": "string",
              "pattern": "^sha256:[A-Za-z0-9._-]+$"
            }
          },
          "required": [
            "id",
            "schema",
            "digest"
          ],
          "additionalProperties": false
        },
        "runner": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "workspaceTemplate": {
              "type": "string",
              "minLength": 1
            },
            "workspaceDigest": {
              "type": "string",
              "pattern": "^sha256:[A-Za-z0-9._-]+$"
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false
        },
        "contextReceipts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": {}
          }
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "actionProposal": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "digest": {
              "type": "string",
              "pattern": "^sha256:[A-Za-z0-9._-]+$"
            }
          },
          "required": [
            "id",
            "digest"
          ],
          "additionalProperties": false
        },
        "approvalDecision": {
          "type": "object",
          "additionalProperties": {}
        },
        "sideEffectReceipt": {
          "type": "object",
          "properties": {
            "adapter": {
              "type": "string",
              "minLength": 1
            },
            "action": {
              "type": "string",
              "minLength": 1
            },
            "status": {
              "type": "string",
              "minLength": 1
            },
            "providerReference": {
              "type": "string",
              "minLength": 1
            },
            "providerUrl": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "adapter",
            "action",
            "status"
          ],
          "additionalProperties": false
        },
        "payloadDigest": {
          "type": "string",
          "pattern": "^sha256:[A-Za-z0-9._-]+$"
        }
      },
      "required": [
        "schema",
        "id",
        "workspaceId",
        "workflowRunId",
        "eventType",
        "occurredAt",
        "actor",
        "workflow",
        "payloadDigest"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
