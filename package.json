{
  "name": "@viewportai/protocol",
  "version": "1.3.1",
  "type": "module",
  "description": "Canonical Viewport protocol contract ids, samples, and compatibility fixtures.",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viewportai/protocol.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema-ids": {
      "types": "./dist/schema-ids.d.ts",
      "import": "./dist/schema-ids.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    },
    "./samples": {
      "types": "./dist/samples.d.ts",
      "import": "./dist/samples.js"
    },
    "./workflow-run": {
      "types": "./dist/workflow-run.d.ts",
      "import": "./dist/workflow-run.js"
    }
  },
  "files": [
    "dist",
    "generated",
    "samples",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "generate:json-schemas": "tsx scripts/generate-json-schemas.ts",
    "validate:samples": "tsx scripts/validate-samples.ts",
    "pack:smoke": "node scripts/pack-smoke.mjs"
  },
  "dependencies": {
    "yaml": "^2.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^22.13.4",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "semantic-release": "^24.2.9",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "zod-to-json-schema": "^3.25.2"
  }
}
